# Backend (Railway) — set these in Railway project variables
# Supabase: use service_role key for server-side DB access (Dashboard → API)

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server
PORT=3001

# Email sending (configure when you add send function)
# RESEND_API_KEY=...
# or SENDGRID_API_KEY=...

# Optional: cron secret to secure job endpoints
# CRON_SECRET=...
